generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  description String?
  products    Product[]

  @@map("categories")
}

model Product {
  id              Int      @id @default(autoincrement())
  name            String
  description     String
  price           Float
  discountPercent Float    @default(0)
  stock           Int      @default(10)
  brand           String
  ratingAverage   Float    @default(0)
  ratingCount     Int      @default(0)
  images          String   // JSON-serialized string of image URLs
  specifications  String   // JSON-serialized string of spec key-values
  sellerId        Int
  categoryId      Int
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("products")
}
