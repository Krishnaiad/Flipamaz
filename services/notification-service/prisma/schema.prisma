generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  message   String
  type      String   @default("INFO") // INFO, ORDER, AUTH
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}
